{
    "name": "suggestio",
    "type": "module",
    "displayName": "Suggestio",
    "description": "Autonomous coding agent using free LLM APIs",
    "publisher": "glacode",
    "author": "Glauco Siliprandi",
    "icon": "resources/logo.png",
    "version": "0.1.2",
    "engines": {
        "vscode": "^1.102.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/glacode/suggestio.git"
    },
    "homepage": "https://github.com/glacode/suggestio",
    "bugs": {
        "url": "https://github.com/glacode/suggestio/issues"
    },
    "license": "MIT",
    "keywords": [
        "autocomplete",
        "LLM",
        "inline",
        "code",
        "suggestions",
        "AI"
    ],
    "activationEvents": [
        "onLanguage:javascript",
        "onLanguage:typescript",
        "onLanguage:python",
        "onLanguage:java",
        "onLanguage:c",
        "onLanguage:cpp",
        "onLanguage:csharp",
        "onLanguage:go",
        "onLanguage:php",
        "onLanguage:ruby",
        "onLanguage:rust",
        "onLanguage:html",
        "onLanguage:css",
        "onLanguage:json",
        "onLanguage:markdown",
        "onLanguage:shellscript",
        "onLanguage:yaml",
        "onLanguage:sql"
    ],
    "main": "./dist/extension.js",
    "files-unused-because-we-use-vscodeignore": [
        "dist/**",
        "!dist/**/*.map",
        "builtResources/**",
        "media/**",
        "resources/**"
    ],
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "suggestio",
                    "title": "Suggestio",
                    "icon": "resources/logo.svg"
                }
            ]
        },
        "views": {
            "suggestio": [
                {
                    "id": "suggestio.chat.view",
                    "name": "Chat",
                    "type": "webview",
                    "icon": "resources/logo.svg"
                }
            ]
        },
        "inlineCompletions": [
            {
                "language": "javascript"
            },
            {
                "language": "typescript"
            },
            {
                "language": "python"
            },
            {
                "language": "java"
            },
            {
                "language": "c"
            },
            {
                "language": "cpp"
            },
            {
                "language": "csharp"
            },
            {
                "language": "go"
            },
            {
                "language": "php"
            },
            {
                "language": "ruby"
            },
            {
                "language": "rust"
            },
            {
                "language": "html"
            },
            {
                "language": "css"
            },
            {
                "language": "markdown"
            },
            {
                "language": "shellscript"
            },
            {
                "language": "sql"
            }
        ],
        "commands": [
            {
                "command": "suggestio.editGlobalConfig",
                "title": "Suggestio: Edit Global Config"
            },
            {
                "command": "suggestio.updateApiKey",
                "title": "Suggestio: Update API Key"
            },
            {
                "command": "suggestio.deleteApiKey",
                "title": "Suggestio: Delete API Key"
            },
            {
                "command": "suggestio.openChat",
                "title": "Suggestio: Focus on Chat View"
            },
            {
                "command": "suggestio.newChat",
                "title": "Suggestio: New Chat",
                "icon": "$(add)"
            },
            {
                "command": "suggestio.disableInlineCompletion",
                "title": "Suggestio: Disable Inline Completion",
                "icon": "$(eye)"
            },
            {
                "command": "suggestio.enableInlineCompletion",
                "title": "Suggestio: Enable Inline Completion",
                "icon": "$(eye-closed)"
            },
            {
                "command": "suggestio.disableAutoAcceptEdits",
                "title": "Suggestio: Disable Auto-Accept Edits",
                "icon": "$(zap)"
            },
            {
                "command": "suggestio.enableAutoAcceptEdits",
                "title": "Suggestio: Enable Auto-Accept Edits",
                "icon": "$(shield)"
            },
            {
                "command": "suggestio.selectCompletionProfile",
                "title": "Suggestio: Select Completion Profile",
                "icon": "$(gear)"
            },
            {
                "command": "suggestio.showChatHistory",
                "title": "Suggestio: Show Chat History",
                "icon": "$(history)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "suggestio.newChat",
                    "when": "view == suggestio.chat.view",
                    "group": "navigation@1"
                },
                {
                    "command": "suggestio.showChatHistory",
                    "when": "view == suggestio.chat.view",
                    "group": "navigation@1.2"
                },
                {
                    "command": "suggestio.disableAutoAcceptEdits",
                    "when": "view == suggestio.chat.view && suggestio.autoAcceptEditsEnabled",
                    "group": "navigation@1.5"
                },
                {
                    "command": "suggestio.enableAutoAcceptEdits",
                    "when": "view == suggestio.chat.view && !suggestio.autoAcceptEditsEnabled",
                    "group": "navigation@1.5"
                },
                {
                    "command": "suggestio.disableInlineCompletion",
                    "when": "view == suggestio.chat.view && suggestio.inlineCompletionEnabled",
                    "group": "navigation@2"
                },
                {
                    "command": "suggestio.enableInlineCompletion",
                    "when": "view == suggestio.chat.view && !suggestio.inlineCompletionEnabled",
                    "group": "navigation@2"
                },
                {
                    "command": "suggestio.selectCompletionProfile",
                    "when": "view == suggestio.chat.view",
                    "group": "navigation@3"
                }
            ]
        },
        "jsonValidation": [
            {
                "fileMatch": "config.json",
                "url": "./resources/config.schema.json"
            },
            {
                "fileMatch": "suggestio.config.json",
                "url": "./resources/config.schema.json"
            }
        ],
        "configuration": {
            "title": "Suggestio",
            "properties": {
                "suggestio.maxAgentIterations": {
                    "type": "number",
                    "default": 30,
                    "description": "Maximum number of iterations the agent can perform for a single request."
                },
                "suggestio.maxSavedChatSessions": {
                    "type": "number",
                    "default": 5,
                    "description": "Maximum number of chat sessions to keep in the history."
                },
                "suggestio.inlineCompletion.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Whether to enable inline code completion."
                },
                "suggestio.inlineCompletion.supportedLanguages": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "javascript",
                        "typescript",
                        "python",
                        "java",
                        "c",
                        "cpp",
                        "csharp",
                        "go",
                        "php",
                        "ruby",
                        "rust",
                        "html",
                        "css",
                        "markdown",
                        "shellscript",
                        "sql"
                    ],
                    "description": "Languages where inline completion is active. Excludes .json and .yaml by default for security."
                },
                "suggestio.inlineCompletion.enableInUntitledEditors": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether to enable inline completion in untitled (unsaved) editors."
                },
                "suggestio.logLevel": {
                    "type": "string",
                    "enum": [
                        "Debug",
                        "Info",
                        "Warn",
                        "Error",
                        "Silent"
                    ],
                    "default": "Info",
                    "description": "The level of detail for the logs."
                },
                "suggestio.experimental.anonymizer.enabled": {
                    "type": "boolean",
                    "default": false,
                    "scope": "application",
                    "description": "Enable experimental code anonymization to prevent sensitive information from being sent to LLMs."
                },
                "suggestio.experimental.anonymizer.words": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "scope": "application",
                    "description": "Experimental: List of specific words or identifiers to always anonymize."
                },
                "suggestio.experimental.anonymizer.sensitiveData.allowedEntropy": {
                    "type": "number",
                    "default": 0.85,
                    "scope": "application",
                    "description": "Experimental: Threshold for Shannon entropy detection. Words with higher entropy will be anonymized."
                },
                "suggestio.experimental.anonymizer.sensitiveData.minLength": {
                    "type": "number",
                    "default": 10,
                    "scope": "application",
                    "description": "Experimental: Minimum length of a word to be considered for entropy-based anonymization."
                },
                "suggestio.llm.maxRetries": {
                    "type": "number",
                    "default": 5,
                    "description": "Maximum number of retry attempts for LLM API calls."
                },
                "suggestio.llm.initialDelay": {
                    "type": "number",
                    "default": 1000,
                    "description": "Initial delay in milliseconds for exponential backoff during retries."
                },
                "suggestio.profiles": {
                    "type": "object",
                    "scope": "application",
                    "description": "Configuration for LLM profiles. Each key is a profile name, and the value is its configuration.",
                    "additionalProperties": {
                        "type": "object",
                        "properties": {
                            "model": {
                                "type": "string",
                                "description": "The name of the model to use (e.g., 'gpt-4', 'gemini-pro')."
                            },
                            "endpoint": {
                                "type": "string",
                                "description": "The API endpoint URL (required for OpenAI-compatible profiles)."
                            },
                            "apiKeyIdentifier": {
                                "type": "string",
                                "description": "The identifier for the API key (e.g., 'OPENROUTER_API_KEY'). This identifier is used to look up the actual key in the secret manager or environment variables."
                            },
                            "isApiKeyRequired": {
                                "type": "boolean",
                                "default": true,
                                "description": "Whether an API key is required for this profile. If set to false, no key will be requested."
                            },
                            "type": {
                                "type": "string",
                                "enum": [
                                    "openai-compatible",
                                    "gemini"
                                ],
                                "default": "openai-compatible",
                                "description": "The type of provider."
                            },
                            "supportsTools": {
                                "type": "boolean",
                                "default": true,
                                "description": "Whether the model supports tool calling."
                            },
                            "excludeFromChat": {
                                "type": "boolean",
                                "default": false,
                                "description": "Whether to exclude this model from the chat interface."
                            }
                        },
                        "required": [
                            "model"
                        ],
                        "anyOf": [
                            {
                                "properties": {
                                    "isApiKeyRequired": {
                                        "const": false
                                    }
                                },
                                "required": [
                                    "isApiKeyRequired"
                                ]
                            },
                            {
                                "required": [
                                    "apiKeyIdentifier"
                                ]
                            }
                        ]
                    },
                    "default": {}
                },
                "suggestio.activeChatProfile": {
                    "type": "string",
                    "scope": "application",
                    "description": "The ID of the profile currently active for chat."
                },
                "suggestio.activeCompletionProfile": {
                    "type": "string",
                    "scope": "application",
                    "description": "The ID of the profile currently active for inline completion."
                },
                "suggestio.debug.security.disableSanitizer": {
                    "type": "boolean",
                    "default": false,
                    "description": "WARNING: Only disable this for testing purposes. Disabling the sanitizer exposes the extension to XSS attacks from LLM-generated content. Use only if you suspect the sanitizer is causing rendering issues."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "compile": "npm run check-types && npm run lint && npm run build:webview && npm run copy-css && node esbuild.js",
        "package": "npm run check-types && npm run lint && npm run build:webview && npm run copy-css && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir dist",
        "watch-tests": "tsc -p . -w --outDir dist",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src __tests__ e2e-tests-playwright",
        "test": "node --experimental-vm-modules node_modules/.bin/jest --detectOpenHandles",
        "build:e2e": "tsc -p ./tsconfig.e2e.json && node ./scripts/test/rename-e2e.js",
        "test:e2e": "npm run build:e2e && node ./dist-e2e/runTest.cjs",
        "test:e2e-playwright": "playwright test --config=e2e-tests-playwright/playwright.config.ts",
        "test:e2e-playwright-headless": "xvfb-run -a npm run test:e2e-playwright",
        "test:debug": "node --inspect --experimental-vm-modules node_modules/.bin/jest --runInBand --debug",
        "build:webview": "node esbuild.js",
        "watch:webview": "node esbuild.js --watch",
        "copy-css": "node ./scripts/build/copyCss.js",
        "serve:chat": "node scripts/tools/serve-chat.js",
        "test:providers": "node --env-file=.env scripts/tools/test-providers.js",
        "dev:install": "npx vsce package -o suggestio.vsix && code --install-extension suggestio.vsix --force"
    },
    "dependencies": {
        "dompurify": "^3.4.7",
        "highlight.js": "^11.11.1",
        "marked": "^16.3.0",
        "node-fetch": "^3.3.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@playwright/test": "^1.56.1",
        "@types/dompurify": "^3.0.5",
        "@types/express": "^5.0.5",
        "@types/glob": "^8.1.0",
        "@types/jest": "^30.0.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.102.0",
        "@typescript-eslint/eslint-plugin": "^8.39.0",
        "@typescript-eslint/parser": "^8.39.0",
        "@vscode/test-electron": "^2.5.2",
        "chokidar": "^4.0.3",
        "esbuild": "^0.25.10",
        "eslint": "^9.32.0",
        "express": "^5.1.0",
        "glob": "^11.0.3",
        "jest": "^30.0.5",
        "jest-environment-jsdom": "^30.3.0",
        "mocha": "^11.7.5",
        "npm-run-all": "^4.1.5",
        "ts-jest": "^29.4.1",
        "ts-node": "^10.9.1",
        "typescript": "^5.9.2",
        "ws": "^8.18.3"
    },
    "overrides": {
        "js-yaml": "4.1.1",
        "brace-expansion": "5.0.6",
        "mocha": {
            "diff": "8.0.3",
            "serialize-javascript": "7.0.5"
        }
    }
}
